   "source": [
    "WITH CTE AS (\n",
    "SELECT category, product, SUM(spend) AS total_spend\n",
    "FROM product_spend\n",
    "WHERE EXTRACT(YEAR FROM transaction_date) = 2022\n",
    "GROUP BY category, product\n",
    "),\n",
    "\n",
    "CTE2 AS (\n",
    "SELECT category, product, total_spend, RANK() OVER (PARTITION BY category ORDER BY total_spend DESC) AS ranking\n",
    "FROM CTE\n",
    ")\n",
    "\n",
    "SELECT category, product, total_spend\n",
    "FROM CTE2\n",
    "WHERE ranking <= 2"
   ]
