    "Duplicate Job Listings\n",
    "LinkedIn SQL Interview Question\n",
    "\n",
    "WITH dupes AS (SELECT \n",
    "  company_id, \n",
    "  title, \n",
    "  description, \n",
    "  COUNT(job_id) AS job_count\n",
    "FROM job_listings\n",
    "GROUP BY company_id, title, description)\n",
    "SELECT \n",
    "  SUM(CASE WHEN job_count = 2 THEN 1 ELSE 0 END) AS duplicate_companies\n",
    "FROM dupes"
   ]
  },
