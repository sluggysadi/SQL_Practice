    "POSTGRESSQL\n",
    "SELECT \n",
    "    DATE_TRUNC('month', submit_date)::date as mth,\n",
    "    product_id, \n",
    "    AVG(stars) OVER (PARTITION BY DATE_TRUNC('month', submit_date)::date, product_id )\n",
    "FROM reviews\n",
    "GROUP BY \n",
    "  DATE_TRUNC('month', submit_date)::date, \n",
    "  product_id\n",
    "ORDER BY mth, product\n",
    "\n",
    "MYSQL\n",
    "SELECT \n",
    "    DATE_FORMAT(submit_date, '%Y-%m-01') AS mth,\n",
    "    product_id,\n",
    "    AVG(stars) OVER (\n",
    "        PARTITION BY DATE_FORMAT(submit_date, '%Y-%m-01'), product_id\n",
    "    ) AS avg_stars\n",
    "FROM reviews\n",
    "GROUP BY \n",
    "  DATE_FORMAT(submit_date, '%Y-%m-01') AS mth,\n",
    "  product_id\n",
    "ORDER BY mth, product_id;"
   ]
