    "FAANG STOCK MIN-MAX (PART 1)\n",
    "BLOOMBERG \n",
    "\n",
    "WITH high AS (\n",
    "SELECT \n",
    "  ticker,\n",
    "  TO_CHAR(date, 'Mon-YYYY') AS highest_month,\n",
    "  MAX(open) AS highest_open,\n",
    "  ROW_NUMBER() OVER (PARTITION BY ticker ORDER BY open DESC) AS row_num\n",
    "FROM stock_prices\n",
    "GROUP BY ticker, TO_CHAR(date, 'Mon-YYYY'), open\n",
    "),\n",
    "low as (\n",
    "SELECT \n",
    "  ticker,\n",
    "  TO_CHAR(date, 'Mon-YYYY') AS lowest_mth,\n",
    "  MIN(open) AS lowest_open,\n",
    "  ROW_NUMBER() OVER (PARTITION BY ticker ORDER BY open ASC) AS row_num\n",
    "FROM stock_prices\n",
    "GROUP BY ticker, TO_CHAR(date, 'Mon-YYYY'), open\n",
    ")\n",
    "\n",
    "SELECT high.ticker, \n",
    "      high.highest_month, high.highest_open,\n",
    "      low.lowest_mth, low.lowest_open\n",
    "FROM high \n",
    "  JOIN low ON high.ticker = low.ticker\n",
    "  AND high.row_num = 1 \n",
    "  AND low.row_num = 1\n",
    "ORDER BY high.ticker"
   ]
  }
