   "source": [
    "Spotify Streaming History\n",
    "\n",
    "WITH CTE AS (\n",
    "SELECT \n",
    "  user_id,\n",
    "  song_id,\n",
    "  song_plays\n",
    "FROM songs_history\n",
    "\n",
    "UNION ALL\n",
    "\n",
    "SELECT \n",
    "  user_id,\n",
    "  song_id,\n",
    "  COUNT(listen_time) AS song_plays\n",
    "FROM songs_weekly\n",
    "WHERE listen_time < '08/05/2022'\n",
    "GROUP BY user_id, song_id\n",
    ")\n",
    "\n",
    "SELECT \n",
    "  user_id,\n",
    "  song_id,\n",
    "  SUM(song_plays) AS song_plays\n",
    "FROM CTE\n",
    "GROUP BY user_id, song_id\n",
    "ORDER BY song_plays DESC;\n",
    "  "
   ]
