    "ODD AND EVEN MEASUREMENTS GOOGLE\n",
    "\n",
    "WITH ranked_measurements AS (\n",
    "SELECT \n",
    "  CAST(measurement_time AS DATE) AS measurement_day, \n",
    "  measurement_value, \n",
    "  ROW_NUMBER() OVER (PARTITION BY EXTRACT(DAY FROM measurement_time) ORDER BY measurement_time) AS rownums\n",
    "FROM measurements\n",
    ")\n",
    "\n",
    "SELECT measurement_day, \n",
    "  SUM(CASE WHEN MOD(rownums, 2) != 0 THEN measurement_value ELSE 0 END) AS odd_sum,\n",
    "  SUM(CASE WHEN MOD(rownums, 2) = 0 THEN measurement_value ELSE 0 END) AS even_sum\n",
    "FROM ranked_measurements\n",
    "GROUP BY measurement_day\n",
    "ORDER BY measurement_day\n",
    "\n"
   ]
