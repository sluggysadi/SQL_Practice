    "Well Paid Employees\n",
    "\n",
    "SELECT emp.employee_id, emp.name\n",
    "FROM employee AS mgr -- Represents the manager's table\n",
    "INNER JOIN employee AS emp -- Represent the employee's table\n",
    "  ON mgr.employee_id = emp.manager_id\n",
    "WHERE emp.salary > mgr.salary"
