    "VIP USERS AT SOFI\n",
    "\n",
    "--- VIP USER - 3 LOANS WITH AMOUNT > 20,000\n",
    "--- customer_id join \n",
    "--- COUNT(loan_id) of customer WHERE amount > 20,000\n",
    "--- NOTE DONT NEED customers unless we need names\n",
    "\n",
    "SELECT c.customer_id AS vip_user\n",
    "FROM customers c\n",
    "    JOIN loans l ON \n",
    "    c.customer_id = l.customer_id\n",
    "WHERE l.amount > 20000 \n",
    "    AND loan_date > CURRENT_DATE - INTERVAL '1 year' \n",
    "GROUP BY c.customer_id\n",
    "HAVING COUNT(l.loan_id) > 3"
   ]
