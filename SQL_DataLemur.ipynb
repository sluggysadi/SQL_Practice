   },
   "source": [
    "SELECT ag.age_bucket,\n",
    "ROUND(100.0*SUM(CASE WHEN ac.activity_type = 'send' THEN ac.time_spent ELSE 0 END)/SUM(CASE WHEN activity_type IN ('open', 'send') THEN time_spent ELSE 0 END),2) AS send_perc,\n",
    "ROUND(100.0*SUM(CASE WHEN ac.activity_type = 'open' THEN ac.time_spent ELSE 0 END)/SUM(CASE WHEN activity_type IN ('open', 'send') THEN time_spent ELSE 0 END),2) AS open_perc\n",
    "FROM activities ac\n",
    "  JOIN age_breakdown ag on ag.user_id = ac.user_id\n",
    "GROUP BY ag.age_bucket"
   ]
  },
