    "1581. Customer Who Visited but Did Not Make Any Transactions\n",
    "-- Write your PostgreSQL query statement below\n",
    "SELECT v.customer_id, (COUNT(*) - COUNT(t.transaction_id)) AS count_no_trans\n",
    "FROM visits v\n",
    "    LEFT JOIN Transactions t ON v.visit_id = t.visit_id\n",
    "GROUP BY v.customer_id\n",
    "HAVING COUNT(*) - COUNT(t.transaction_id) > 0;\n",
    "\n",
    "Learned:\n",
    "WHERE does not allow aggregrate functions as it runs before aggregration: only runs in SELECT, HAVING, ORDER BY\n",
    "USE COUNT(*) So it also counts null values COUNT(column) Only rows where column is NOT NULL\n",
    "\n",
    "In this example LEFT JOIN transactions t ON v.visit_id = t.visit_id -> visit_id : 1, 2 transaction_id 2, null respectively \n",
    "\n",
    "\t•\tCOUNT(*) → counts both rows (2)\n",
    "\t•\tCOUNT(t.transaction_id) → counts only 1 (because NULL is ignored)"
   ]
  },
