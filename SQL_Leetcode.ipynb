   "source": [
    "WITH\n",
    "quality_table AS (\n",
    "    SELECT\n",
    "        query_name,\n",
    "        ROUND(SUM(rating * 1.0 / position) / COUNT(*), 2) AS quality\n",
    "    FROM Queries\n",
    "    GROUP BY query_name\n",
    "),\n",
    "poor_table AS (\n",
    "    SELECT\n",
    "        query_name,\n",
    "        ROUND((SUM(CASE WHEN rating < 3 THEN 1 ELSE 0 END)/ COUNT(*) * 100.0), 2) AS poor_query_percentage\n",
    "    FROM Queries\n",
    "    GROUP BY query_name\n",
    ")\n",
    "SELECT\n",
    "    q.query_name,\n",
    "    q.quality,\n",
    "    p.poor_query_percentage\n",
    "FROM quality_table q\n",
    "JOIN poor_table p\n",
    "  ON q.query_name = p.query_name;\n",
    "\n",
    "Easier optimized query\n",
    "SELECT QUERY_NAME, ROUND(AVG(RATING/POSITION), 2) AS QUALITY, ROUND(AVG(IF(RATING<3,1,0))*100, 2) AS POOR_QUERY_PERCENTAGE\n",
    "FROM QUERIES\n",
    "GROUP BY QUERY_NAME"
   ]
  },
