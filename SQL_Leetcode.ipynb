    "550. Game Play Analysis IV\n",
    "\n",
    "WITH first_login AS (\n",
    "    SELECT\n",
    "        player_id,\n",
    "        MIN(event_date) AS event_date\n",
    "    FROM activity\n",
    "    GROUP BY player_id\n",
    ")\n",
    "\n",
    "SELECT\n",
    "    ROUND(\n",
    "        COUNT(first_login.player_id)\n",
    "        /\n",
    "        (SELECT COUNT(DISTINCT player_id) FROM first_login),\n",
    "        2\n",
    "    ) AS fraction\n",
    "\n",
    "FROM first_login\n",
    "JOIN activity a\n",
    "    ON  first_login.player_id  = a.player_id\n",
    "    AND first_login.event_date = DATE_SUB(a.event_date, INTERVAL 1 DAY);"
   ]
  },
