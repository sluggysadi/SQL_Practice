   "source": [
    "SELECT a.machine_id, round(avg(b.timestamp-a.timestamp)::numeric, 3) AS processing_time \n",
    "FROM Activity a\n",
    "    JOIN Activity b ON a.machine_id = b.machine_id\n",
    "    WHERE a.process_id = b.process_id AND\n",
    "    a.activity_type ='start' AND \n",
    "    b.activity_type ='end'\n",
    "GROUP BY a.machine_id"
   ]
