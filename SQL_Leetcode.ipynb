    "1321. Restaurant Growth\n",
    "\n",
    "# Write your MySQL query statement below\n",
    "# average_amount: window function AVG(amount) OVER (ORDER BY visited_on, ROWS  # BETWEEN 6 PRECEDING AND CURRENT ROW)\n",
    "SELECT visited_on, amount, average_amount FROM (\n",
    "SELECT visited_on, SUM(daily_amount) OVER (ORDER BY visited_on ROWS BETWEEN 6 PRECEDING AND CURRENT ROW) AS amount,\n",
    "ROUND(AVG(daily_amount) OVER (ORDER BY visited_on ROWS BETWEEN 6 PRECEDING AND CURRENT ROW), 2) AS average_amount, ROW_NUMBER() OVER (ORDER BY visited_on) AS rn\n",
    "FROM (\n",
    "    SELECT visited_on, SUM(amount) AS daily_amount\n",
    "    FROM Customer\n",
    "    GROUP BY visited_on\n",
    ") t1\n",
    "GROUP BY visited_on\n",
    "ORDER BY visited_on ) t2\n",
    "WHERE rn >= 7"
   ]
  },
