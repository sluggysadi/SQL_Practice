    "WITH single_num AS (\n",
    "SELECT ifnull(num, null) as num\n",
    "FROM MyNumbers\n",
    "GROUP BY num\n",
    "HAVING COUNT(num) = 1\n",
    "ORDER BY num DESC\n",
    ")\n",
    "SELECT MAX(num) as num\n",
    "FROM single_num"
   ]
